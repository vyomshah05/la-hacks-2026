{
  "expo": {
    "name": "TrailSafe",
    "slug": "trail-safe",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "trailsafe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2f7d4f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
