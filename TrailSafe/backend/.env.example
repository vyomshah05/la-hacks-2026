# Which provider to route /chat through.
# Supported: openai | anthropic | gemini
PROVIDER=openai

# Model id to pass to the chosen provider.
# openai: gpt-4o-mini, gpt-4o, gpt-4.1-mini, ...
# anthropic: claude-sonnet-4-6, claude-haiku-4-5, ...
# gemini: gemini-2.0-flash, gemini-2.5-pro, ...
MODEL=gpt-4o-mini

# Provider API keys. Set only the one you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Server config
HOST=0.0.0.0
PORT=8000
